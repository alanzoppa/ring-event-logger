# Ring refresh token (get with: npm run auth)
RING_REFRESH_TOKEN=your-refresh-token-here

# Data directory for SQLite and token storage
DATA_DIR=./data

# Poll interval for camera status (seconds)
POLL_INTERVAL=20

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Webhooks are configured in webhooks.json
# See webhooks.json.example for configuration options
